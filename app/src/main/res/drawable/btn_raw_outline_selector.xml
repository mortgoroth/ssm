<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Состояние: RAW ЛОГ ВКЛЮЧЕН (Кнопка нажата) -->
    <item android:state_checked="true">
        <shape android:shape="rectangle">
            <corners android:radius="8dp"/>
            <solid android:color="@android:color/transparent"/>
            <!-- Яркая рамка под основной цвет текста темы (черный днем / белый ночью) -->
            <stroke android:width="2dp" android:color="?android:attr/textColorPrimary"/>
        </shape>
    </item>

    <!-- Состояние: RAW ЛОГ ВЫКЛЮЧЕН (Обычный вид) -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="8dp"/>
            <solid android:color="@android:color/transparent"/>
            <!-- Блёклая рамка -->
            <stroke android:width="2dp" android:color="#44FFFFFF"/>
        </shape>
    </item>
</selector>
