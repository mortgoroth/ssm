<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <TextView
        android:id="@+id/lblConsoleHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="System Terminal:"
        android:textColor="?android:attr/textColorPrimary"
        android:textSize="14sp"
        android:textStyle="bold"
        android:layout_marginBottom="4dp" />

    <!-- scrollContainer забирает всё свободное место -->
    <!-- ВЕРХНЯЯ ЧАСТЬ: Чистый результирующий паспорт (Всегда виден сверху) -->
    <TextView
        android:id="@+id/txtConsole"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Нажмите Test Connect для инициализации K-Line кабеля..."
        android:textColor="?android:attr/textColorPrimary"
        android:textSize="13sp"
        android:fontFamily="monospace"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"
        android:padding="4dp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#A0A0A0"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Сырой RX/TX лог обмена К-линии:"
        android:textSize="11sp"
        android:textColor="#757575"
        android:layout_marginBottom="4dp" />

    <!-- НИЖНЯЯ ЧАСТЬ: Изолированное черное окно дебага для сырых байт (забирает всё свободное место) -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#1E1E1E"
        android:padding="6dp">

        <TextView
            android:id="@+id/txtDebugLogConsole"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:text="" />
    </ScrollView>

    <!-- 🛠️ ВСПЛЫВАЮЩАЯ КНОПКА СБРОСА ОШИБОК (Изначально скрыта!) -->
    <LinearLayout
        android:id="@+id/layoutClearContainer"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="6dp"
        android:visibility="gone">

        <View
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1" />

        <Button
            android:id="@+id/btnClear"
            android:layout_width="160dp"
            android:layout_height="45dp"
            android:text="Clear Codes"
            android:backgroundTint="#D32F2F" />
    </LinearLayout>
</LinearLayout>