<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://android.com"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="6dp"
    android:background="?android:attr/windowBackground">

    <com.google.android.material.button.MaterialButtonToggleGroup
        android:id="@+id/toggleButtonGroup"
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:orientation="horizontal"
        xmlns:app="http://android.com"
        app:singleSelection="true"
        app:selectionRequired="true"
        app:checkedButton="@id/btnGlobalLogs"
        android:layout_marginTop="4dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnTestConnect"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Connect"
            android:textSize="11sp"
            android:padding="0dp"
            android:enabled="false"
            android:stateListAnimator="@null"
            android:backgroundTint="#2196F3"
            android:textColor="#FFFFFF" />

        <!-- Кнопка CODES: Жёстко заблокирована и принудительно выкрашена в СЕРЫЙ цвет -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCodes"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Codes"
            android:textSize="11sp"
            android:padding="0dp"
            android:enabled="false"
            android:stateListAnimator="@null"
            android:backgroundTint="#B0BEC5"
            android:textColor="#FFFFFF" />

        <!-- Кнопка BLOCKS: Жёстко заблокирована и принудительно выкрашена в СЕРЫЙ цвет -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnData"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Blocks"
            android:textSize="11sp"
            android:padding="0dp"
            android:enabled="false"
            android:stateListAnimator="@null"
            android:backgroundTint="#B0BEC5"
            android:textColor="#FFFFFF" />

        <!-- Кнопка LOGS: Со старта горит сочным ЯРКО-ГОЛУБЫМ цветом, активна и разблокирована -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGlobalLogs"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Logs"
            android:textSize="11sp"
            android:padding="0dp"
            android:stateListAnimator="@null"
            android:backgroundTint="#2196F3"
            android:textColor="#FFFFFF" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnExit"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Exit"
            android:textSize="11sp"
            android:padding="0dp"
            android:stateListAnimator="@null"
            android:backgroundTint="#D32F2F"
            android:textColor="#FFFFFF" />

    </com.google.android.material.button.MaterialButtonToggleGroup>

    <!-- 🟢 УЛЬТРА-КОМПАКТНЫЙ ПАСПОРТ ЭБУ (В одну горизонтальную линию) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="4dp"
        android:weightSum="3">

        <TextView
            android:id="@+id/lblEngineType"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Engine: ---"
            android:textColor="?android:attr/textColorPrimary"
            android:textSize="11sp"
            android:textStyle="bold"
            android:singleLine="true" />

        <TextView
            android:id="@+id/lblRomId"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="ROM: ---"
            android:textColor="@color/rom_id_text"
            android:textSize="11sp"
            android:textStyle="bold"
            android:gravity="center"
            android:singleLine="true" />

        <TextView
            android:id="@+id/lblMeasuringBlocksHeader"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Blocks: D:00 S:00"
            android:textColor="?android:attr/textColorPrimary"
            android:textSize="11sp"
            android:textStyle="bold"
            android:gravity="end"
            android:singleLine="true" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#B0BEC5"
        android:layout_marginBottom="4dp" />

</LinearLayout>