<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://android.com"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- Горизонтальный контейнер деления экрана пополам -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal">

        <!-- 📊 1. ТАБЛИЦА ДАТЧИКОВ -->
        <include layout="@layout/layout_sensor_table" />
        <!-- 📈 2. ГРАФИКИ ДАТЧИКОВ -->
        <include layout="@layout/layout_sensor_graph" />
        <!-- 📈 3. Компактный режим -->
        <include layout="@layout/layout_sensor_compact" />
        <!-- 🖥️ 4. ПАНЕЛЬ HEX-ДЕБАГА -->
        <include layout="@layout/layout_debug_monitor" />

    </LinearLayout>

    <!-- 🛠️ ПОЛНОСТЬЮ АВТОНОМНЫЙ НИЖНИЙ БЛОК УПРАВЛЕНИЯ ДАТЧИКАМИ -->
    <!-- 🟢 КНОПКИ УПРАВЛЕНИЯ ПАРАМЕТРАМИ: ИСПРАВЛЕННЫЙ БЕЗКОНФЛИКТНЫЙ ВАРИАНТ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="4dp"
        xmlns:app="http://android.com">

        <!-- Переключатель Debug mode (RAW) — Оставляем как есть, он работал хорошо -->
        <ToggleButton
            android:id="@+id/btnDebugMode"
            android:layout_width="90dp"
            android:layout_height="40dp"
            android:textOn="RAW: ON"
            android:textOff="RAW"
            android:checked="false"
            android:textSize="12sp"
            android:background="@drawable/btn_raw_outline_selector"
            app:backgroundTint="@android:color/transparent"
            android:textColor="@color/btn_raw_text_selector"/>

        <!-- Невидимая распорка, которая сдвигает кнопки управления вправо -->
        <View
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1" />

        <!-- Кнопка переключения режимов отображения (Table/Graph/Compact)
             🟢 ИСПРАВЛЕНО: Убран android:background, заменен на чистый Material Outlined стиль -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnToggleViewMode"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="View: Table"
            android:textSize="12sp"
            android:layout_marginEnd="6dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            app:backgroundTint="#FFFFFF"
            android:textColor="#2196F3"
            app:strokeColor="#2196F3"
            app:strokeWidth="1dp" />

        <!-- Боевая кнопка запуска опроса K-Line (Start / Stop)
             🟢 ИСПРАВЛЕНО: Сделана сочной, голубой, со скруглениями Material дизайна -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnStartStop"
            android:layout_width="100dp"
            android:layout_height="40dp"
            android:text="Start"
            android:textSize="12sp"
            android:padding="0dp"
            app:backgroundTint="#2196F3"
            android:textColor="#FFFFFF"
            app:cornerRadius="4dp" />

    </LinearLayout>
</LinearLayout>
